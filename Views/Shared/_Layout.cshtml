<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Casa Purita RMS</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="~/css/style.css" />
</head>
<body>
    <div class="d-flex">

        <!-- SIDEBAR -->
        <nav class="sidebar">
            <div class="sidebar-logo">
                <i class=""></i> Casa Purita
            </div>
            <ul class="sidebar-menu">
                <li>
                    <a asp-controller="Room" asp-action="Index"
                       class="@(ViewContext.RouteData.Values["controller"].ToString() == "Room" ? "active" : "")">
                        <i class="bi bi-door-open"></i> Room
                    </a>
                </li>
                <li>
                    <a asp-controller="Tenant" asp-action="Index"
                       class="@(ViewContext.RouteData.Values["controller"].ToString() == "Tenant" ? "active" : "")">
                        <i class="bi bi-people"></i> Tenant
                    </a>
                </li>
            </ul>
        </nav>

        <!-- MAIN CONTENT -->
        <div class="main-content w-100">

            <!-- TOP BAR -->
            <div class="topbar d-flex justify-content-between align-items-center">
                <h5 class="m-0">@ViewData["Title"]</h5>
                <div class="user-avatar">A</div>
            </div>

            <!-- PAGE CONTENT -->
            <div class="p-4">
                @RenderBody()
            </div>

        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>