<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Casa Purita RMS</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="~/css/style.css" />
</head>
<body>
    <div class="app-wrapper">

        <!-- SIDEBAR -->
        <nav class="sidebar" id="sidebar">

            <div class="sidebar-header">
                <div class="sidebar-logo">
                    <i class="bi bi-building"></i>
                    <span class="logo-text">Casa Purita</span>
                </div>
                <button type="button" class="collapse-btn" id="collapseBtn" title="Collapse sidebar">
                    <i class="bi bi-chevron-double-left"></i>
                </button>
            </div>

            <ul class="sidebar-menu">

                <li>
                    <a asp-controller="Unit" asp-action="Index"
                       class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Unit" ? "active" : "")">
                        <i class="bi bi-door-open menu-icon"></i>
                        <span class="menu-text">Unit</span>
                    </a>
                </li>

                <li>
                    <a asp-controller="Tenant" asp-action="Index"
                       class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Tenant" ? "active" : "")">
                        <i class="bi bi-people menu-icon"></i>
                        <span class="menu-text">Tenant</span>
                    </a>
                </li>

                <li>
                    <a asp-controller="RentPayment" asp-action="Index"
                       class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "RentPayment" ? "active" : "")">
                        <i class="bi bi-cash-coin menu-icon"></i>
                        <span class="menu-text">Rent Payment</span>
                    </a>
                </li>

              @*   <li>
                    <a asp-controller="Maintenance" asp-action="Index"
                       class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Maintenance" ? "active" : "")">
                        <i class="bi bi-tools menu-icon"></i>
                        <span class="menu-text">Maintenance</span>
                    </a>
                </li>
 *@
              @*   <li>
                    <a asp-controller="Notification" asp-action="Index"
                       class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Notification" ? "active" : "")">
                        <i class="bi bi-bell menu-icon"></i>
                        <span class="menu-text">Notifications</span>
                    </a>
                </li> *@

               @*  <li>
                    <a asp-controller="Report" asp-action="Index"
                       class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Report" ? "active" : "")">
                        <i class="bi bi-file-earmark-text menu-icon"></i>
                        <span class="menu-text">Reports</span>
                    </a>
                </li> *@

               @*  <li>
                    <a asp-controller="Analytics" asp-action="Index"
                       class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Analytics" ? "active" : "")">
                        <i class="bi bi-bar-chart menu-icon"></i>
                        <span class="menu-text">Analytics</span>
                    </a>
                </li> *@

            </ul>
        </nav>

        <!-- MAIN CONTENT -->
        <div class="main-content">

            <!-- TOPBAR -->
            <div class="topbar">
                <h5 class="topbar-title">@ViewData["Title"]</h5>
                <div class="user-avatar">
                    @(User?.Identity?.IsAuthenticated == true && !string.IsNullOrEmpty(User.Identity.Name)
                        ? User.Identity.Name.Substring(0, 1).ToUpper()
                        : "A")
                </div>
            </div>

            <!-- PAGE CONTENT -->
            <div class="page-body">
                @RenderBody()
            </div>

        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        document.getElementById('collapseBtn').addEventListener('click', function () {
        document.getElementById('sidebar').classList.toggle('collapsed');
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>