@model CasaPuritaRMS.Models.RentPayment

@{
    ViewData["Title"] = "Delete Payment";

    string statusClass = Model.Payment_Status switch
    {
        "Paid" => "badge-available",
        "Overdue" => "badge-occupied",
        _ => "badge-no"
    };

    string statusLabel = Model.Payment_Status switch
    {
        "Paid" => "Paid",
        "Overdue" => "Overdue",
        _ => "Pending"
    };
}

<div class="card-panel delete-card">

    <div class="delete-icon-wrap">
        <i class="bi bi-exclamation-triangle-fill"></i>
    </div>

    <h6 class="delete-title">Delete this payment record?</h6>
    <p class="delete-subtitle">
        This action is permanent and cannot be undone. The receipt and payment history for this transaction will be removed.
    </p>

    <div class="delete-preview">
        <div class="delete-avatar delete-avatar-icon">
            <i class="bi bi-receipt"></i>
        </div>
        <div class="delete-preview-info">
            <span class="delete-preview-name">Receipt #@Model.Receipt_Number</span>
            <span class="delete-preview-meta">@Model.Tenant?.First_Name @Model.Tenant?.Last_Name</span>
            <span class="delete-preview-meta">
                ₱@Model.Amount_Paid.ToString("N2") paid &middot; Due @Model.Due_Date.ToString("MMM dd, yyyy")
            </span>
        </div>
        <span class="@statusClass delete-preview-badge">@statusLabel</span>
    </div>

    <form asp-action="Delete" method="post">
        <input type="hidden" asp-for="Payment_ID" />
        <div class="form-actions">
            <a asp-action="Index" class="btn btn-outline-secondary btn-sm">Cancel</a>
            <button type="submit" class="btn btn-danger-custom btn-sm">
                <i class="bi bi-trash"></i> Delete Payment
            </button>
        </div>
    </form>

</div>