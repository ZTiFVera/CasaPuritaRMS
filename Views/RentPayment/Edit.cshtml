@model CasaPuritaRMS.Models.RentPayment

@{
    ViewData["Title"] = "Edit Rent Payment";
}

<div class="card-panel form-card">

    <div class="form-header">
        <h6>Edit Rent Payment</h6>
        <p class="form-subtitle">Update payment details for Receipt #@Model.Receipt_Number</p>
    </div>

    <form asp-action="Edit" method="post">
        <input type="hidden" asp-for="Payment_ID" />
        <input type="hidden" asp-for="Receipt_Number" />
        <div asp-validation-summary="ModelOnly" class="form-error-summary"></div>

        <!-- TENANT -->
        <div class="form-section">
            <h6 class="form-section-title">Tenant</h6>

            <div class="form-group form-group-full">
                <label asp-for="Tenant_ID" class="form-label">Tenant</label>
                <select asp-for="Tenant_ID" class="form-control-custom" asp-items="ViewBag.Tenant_ID">
                    <option value="">-- Select Tenant --</option>
                </select>
                <span asp-validation-for="Tenant_ID" class="form-error"></span>
            </div>
        </div>

        <!-- PAYMENT AMOUNTS -->
        <div class="form-section">
            <h6 class="form-section-title">Payment Amounts</h6>

            <div class="form-grid">
                <div class="form-group">
                    <label asp-for="Monthly_Rent" class="form-label"></label>
                    <input asp-for="Monthly_Rent" class="form-control-custom" />
                    <span asp-validation-for="Monthly_Rent" class="form-error"></span>
                </div>
                <div class="form-group">
                    <label asp-for="Down_Payment" class="form-label"></label>
                    <input asp-for="Down_Payment" class="form-control-custom" />
                    <span asp-validation-for="Down_Payment" class="form-error"></span>
                </div>
            </div>

            <div class="form-group form-group-full">
                <label asp-for="Amount_Paid" class="form-label"></label>
                <input asp-for="Amount_Paid" class="form-control-custom" />
                <span asp-validation-for="Amount_Paid" class="form-error"></span>
            </div>
        </div>

        <!-- SCHEDULE -->
        <div class="form-section">
            <h6 class="form-section-title">Payment Schedule</h6>

            <div class="form-grid">
                <div class="form-group">
                    <label asp-for="Payment_Date" class="form-label"></label>
                    <input asp-for="Payment_Date" type="date" class="form-control-custom" />
                    <span asp-validation-for="Payment_Date" class="form-error"></span>
                </div>
                <div class="form-group">
                    <label asp-for="Due_Date" class="form-label"></label>
                    <input asp-for="Due_Date" type="date" class="form-control-custom" />
                    <span asp-validation-for="Due_Date" class="form-error"></span>
                </div>
            </div>
        </div>

        <!-- ACTIONS -->
        <div class="form-actions">
            <a asp-action="Index" class="btn btn-outline-secondary btn-sm">Cancel</a>
            <button type="submit" class="btn btn-primary btn-sm">
                <i class="bi bi-check-lg"></i> Update Payment
            </button>
        </div>
    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}