@model CasaPuritaRMS.Models.RentPayment

<div class="pay-summary">
    <h6 class="pay-title">Rent for Unit @Model.Tenant?.Unit?.Unit_Number</h6>
    <p class="pay-sub">@Model.Tenant?.First_Name @Model.Tenant?.Last_Name</p>

    <p class="pay-line">Original Amount: ₱@Model.Monthly_Rent.ToString("N2")</p>
    <p class="pay-line">Charge Due: @Model.Due_Date.ToString("MM/dd/yyyy")</p>
    @if (Model.Overdue_Days > 0)
    {
        <p class="pay-line pay-line-red">Overdue By: @Model.Overdue_Days days</p>
    }
    @if (Model.Advance_Credit > 0)
    {
        <p class="pay-line">Advance / Overpayment: ₱@Model.Advance_Credit.ToString("N2")</p>
    }

    <div class="pay-balance">
        <i class="bi bi-exclamation-circle-fill"></i>
        <span><strong>Balance Remaining</strong> &nbsp; ₱@Model.Balance.ToString("N2")</span>
    </div>
</div>

<form id="recordPaymentForm" asp-action="RecordPayment" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" name="Payment_ID" value="@Model.Payment_ID" />

    <div class="form-group form-group-full">
        <label class="form-label">Amount Paid</label>
        <input name="Amount_Paid" type="number" step="0.01" min="0" class="form-control-custom" placeholder="0.00" />
    </div>

    <div class="form-group form-group-full">
        <label class="form-label">Date Paid</label>
        <input name="Payment_Date" type="date" class="form-control-custom" value="@DateTime.Today.ToString("yyyy-MM-dd")" />
    </div>
</form>