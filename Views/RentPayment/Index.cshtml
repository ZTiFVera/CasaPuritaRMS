@model IEnumerable<CasaPuritaRMS.Models.RentPayment>

@{
    ViewData["Title"] = "Rent Payments";
}

<div class="card-panel">

    <div class="card-panel-header">
        <h6>Rent Payment List</h6>
        <a asp-action="Create" class="btn btn-sm btn-primary">
            <i class="bi bi-plus-lg"></i> Add Payment
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success py-2 mx-4 mt-3">@TempData["Success"]</div>
    }

    <table class="table align-middle">
        <thead>
            <tr>
                <th style="width:13%">Tenant</th>
                <th style="width:10%">Monthly Rent</th>
                <th style="width:10%">Down Payment</th>
                <th style="width:10%">Amount Paid</th>
                <th style="width:9%">Amount Due</th>
                <th style="width:11%">Advance Payment</th>
                <th style="width:9%">Payment Date</th>
                <th style="width:9%">Due Date</th>
                <th style="width:8%">Status</th>
                <th style="width:11%" class="text-end">Actions</th>
            </tr>
        </thead>
        <tbody>
            @if (!Model.Any())
            {
                <tr>
                    <td colspan="10" class="text-center text-muted py-5">
                        <i class="bi bi-cash-coin fs-3 d-block mb-2"></i>
                        No rent payments recorded yet.
                    </td>
                </tr>
            }
            @foreach (var item in Model)
            {
                // CALCULATE Amount Due
                decimal amountDue = item.Monthly_Rent - item.Amount_Paid;
                if (amountDue < 0) amountDue = 0;

                // CALCULATE Advance Payment (automatic)
                decimal advancePayment = item.Amount_Paid > item.Monthly_Rent
                    ? item.Amount_Paid - item.Monthly_Rent
                    : 0;

                <tr>
                    <td>@item.Tenant?.First_Name @item.Tenant?.Last_Name</td>
                    <td>₱@item.Monthly_Rent.ToString("N2")</td>
                    <td>₱@item.Down_Payment.ToString("N2")</td>
                    <td>₱@item.Amount_Paid.ToString("N2")</td>
                    <td>
                        @if (amountDue > 0)
                        {
                            <span class="badge-occupied">₱@amountDue.ToString("N2")</span>
                        }
                        else
                        {
                            <span class="badge-available">₱0.00</span>
                        }
                    </td>
                    <td>
                        @if (advancePayment > 0)
                        {
                            <span class="badge-yes">₱@advancePayment.ToString("N2")</span>
                        }
                        else
                        {
                            <span class="badge-no">₱0.00</span>
                        }
                    </td>
                    <td>@item.Payment_Date.ToString("MMM dd, yyyy")</td>
                    <td>@item.Due_Date.ToString("MMM dd, yyyy")</td>
                    <td>
                        @if (item.Payment_Status == "Paid")
                        {
                            <span class="badge-available">Paid</span>
                        }
                        else
                        {
                            <span class="badge-occupied">Overdue</span>
                        }
                    </td>
                    <td class="text-end">
                        <div class="btn-group btn-group-sm" role="group">
                            <a asp-action="Edit" asp-route-id="@item.Payment_ID" class="btn btn-outline-secondary" title="Edit">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <a asp-action="Details" asp-route-id="@item.Payment_ID" class="btn btn-outline-secondary" title="View">
                                <i class="bi bi-eye"></i>
                            </a>
                            <a asp-action="Delete" asp-route-id="@item.Payment_ID" class="btn btn-outline-danger" title="Delete">
                                <i class="bi bi-trash"></i>
                            </a>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>