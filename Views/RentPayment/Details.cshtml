@model CasaPuritaRMS.Models.RentPayment

@{
    ViewData["Title"] = "Payment Details";

    string statusClass = Model.Payment_Status switch
    {
        "Paid" => "badge-available",
        "Late" => "badge-occupied",
        _ => "badge-maintenance"
    };
}

<div class="card-panel detail-card">

    <div class="detail-header">
        <div class="detail-avatar detail-avatar-icon">
            <i class="bi bi-receipt"></i>
        </div>
        <div class="detail-header-info">
            <h5>Receipt #@Model.Receipt_Number</h5>
            <span class="@statusClass">@Model.Payment_Status</span>
        </div>
    </div>

    <div class="detail-section">
        <h6 class="detail-section-title">Tenant</h6>
        <div class="detail-grid">
            <div class="detail-item">
                <span class="detail-label">Name</span>
                <span class="detail-value">@Model.Tenant?.First_Name @Model.Tenant?.Last_Name</span>
            </div>
            <div class="detail-item">
                <span class="detail-label">Unit</span>
                <span class="detail-value">@Model.Tenant?.Unit?.Unit_Number</span>
            </div>
        </div>
    </div>

    <div class="detail-section">
        <h6 class="detail-section-title">Payment Breakdown</h6>
        <div class="detail-grid">
            <div class="detail-item">
                <span class="detail-label">Monthly Rent</span>
                <span class="detail-value">₱@Model.Monthly_Rent.ToString("N2")</span>
            </div>
            <div class="detail-item">
                <span class="detail-label">Amount Paid</span>
                <span class="detail-value">₱@Model.Amount_Paid.ToString("N2")</span>
            </div>
            <div class="detail-item">
                <span class="detail-label">Balance</span>
                @if (Model.Balance > 0)
                {
                    <span class="badge-occupied">₱@Model.Balance.ToString("N2")</span>
                }
                else
                {
                    <span class="badge-available">₱0.00</span>
                }
            </div>
            <div class="detail-item">
                <span class="detail-label">Advance / Overpayment</span>
                @if (Model.Advance_Credit > 0)
                {
                    <span class="badge-yes">₱@Model.Advance_Credit.ToString("N2")</span>
                }
                else
                {
                    <span class="badge-no">₱0.00</span>
                }
            </div>
        </div>
    </div>

    <div class="detail-section">
        <h6 class="detail-section-title">Schedule</h6>
        <div class="detail-grid">
            <div class="detail-item">
                <span class="detail-label">Payment Date</span>
                <span class="detail-value">@Model.Payment_Date.ToString("MMM dd, yyyy")</span>
            </div>
            <div class="detail-item">
                <span class="detail-label">Due Date</span>
                <span class="detail-value">@Model.Due_Date.ToString("MMM dd, yyyy")</span>
            </div>
        </div>
    </div>

    <div class="detail-actions">
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-arrow-left"></i> Back to List
        </a>
    </div>

</div>