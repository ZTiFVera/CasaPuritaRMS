@model CasaPuritaRMS.Models.RentPayment

@{
    ViewData["Title"] = "Payment Details";

    decimal amountDue = Model.Monthly_Rent - Model.Amount_Paid;
    if (amountDue < 0) amountDue = 0;

    decimal advancePayment = Model.Amount_Paid > Model.Monthly_Rent
        ? Model.Amount_Paid - Model.Monthly_Rent
        : 0;

    string statusClass = Model.Payment_Status == "Paid" ? "badge-available" : "badge-occupied";
    string statusLabel = Model.Payment_Status == "Paid" ? "Paid" : "Overdue";
}

<div class="card-panel detail-card">

    <!-- RECEIPT HEADER -->
    <div class="detail-header">
        <div class="detail-avatar detail-avatar-icon">
            <i class="bi bi-receipt"></i>
        </div>
        <div class="detail-header-info">
            <h5>Receipt #@Model.Receipt_Number</h5>
            <span class="@statusClass">@statusLabel</span>
        </div>
    </div>

    <!-- TENANT -->
    <div class="detail-section">
        <h6 class="detail-section-title">Tenant</h6>
        <div class="detail-grid">
            <div class="detail-item detail-item-full">
                <span class="detail-label">Name</span>
                <span class="detail-value">@Model.Tenant?.First_Name @Model.Tenant?.Last_Name</span>
            </div>
        </div>
    </div>

    <!-- PAYMENT BREAKDOWN -->
    <div class="detail-section">
        <h6 class="detail-section-title">Payment Breakdown</h6>
        <div class="detail-grid">
            <div class="detail-item">
                <span class="detail-label">Monthly Rent</span>
                <span class="detail-value">₱@Model.Monthly_Rent.ToString("N2")</span>
            </div>
            <div class="detail-item">
                <span class="detail-label">Down Payment</span>
                <span class="detail-value">₱@Model.Down_Payment.ToString("N2")</span>
            </div>
            <div class="detail-item">
                <span class="detail-label">Amount Paid</span>
                <span class="detail-value">₱@Model.Amount_Paid.ToString("N2")</span>
            </div>
            <div class="detail-item">
                <span class="detail-label">Amount Due</span>
                @if (amountDue > 0)
                {
                    <span class="badge-occupied">₱@amountDue.ToString("N2")</span>
                }
                else
                {
                    <span class="badge-available">₱0.00</span>
                }
            </div>
            <div class="detail-item detail-item-full">
                <span class="detail-label">Advance Payment</span>
                @if (advancePayment > 0)
                {
                    <span class="badge-yes">₱@advancePayment.ToString("N2")</span>
                }
                else
                {
                    <span class="badge-no">₱0.00</span>
                }
            </div>
        </div>
    </div>

    <!-- SCHEDULE -->
    <div class="detail-section">
        <h6 class="detail-section-title">Payment Schedule</h6>
        <div class="detail-grid">
            <div class="detail-item">
                <span class="detail-label">Payment Date</span>
                <span class="detail-value">@Model.Payment_Date.ToString("MMM dd, yyyy")</span>
            </div>
            <div class="detail-item">
                <span class="detail-label">Due Date</span>
                <span class="detail-value">@Model.Due_Date.ToString("MMM dd, yyyy")</span>
            </div>
        </div>
    </div>

    <!-- ACTIONS -->
    <div class="detail-actions">
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-arrow-left"></i> Back to List
        </a>
        <a asp-action="Edit" asp-route-id="@Model.Payment_ID" class="btn btn-primary btn-sm">
            <i class="bi bi-pencil"></i> Edit Payment
        </a>
    </div>

</div>