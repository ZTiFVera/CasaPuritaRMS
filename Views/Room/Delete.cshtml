@model CasaPuritaRMS.Models.Room

@{
    ViewData["Title"] = "Delete Room";
}

<div class="card-panel" style="max-width:600px;">
    <h6 class="mb-3 text-danger">Delete Room</h6>

    <div class="alert alert-danger py-2">
        Are you sure you want to delete this room? This action cannot be undone.
    </div>

    <dl class="row">
        <dt class="col-sm-4 text-muted small">Room Number</dt>
        <dd class="col-sm-8">@Model.Room_Number</dd>

        <dt class="col-sm-4 text-muted small">Floor</dt>
        <dd class="col-sm-8">@Model.Floor</dd>

        <dt class="col-sm-4 text-muted small">Capacity</dt>
        <dd class="col-sm-8">@Model.Capacity</dd>

        <dt class="col-sm-4 text-muted small">Status</dt>
        <dd class="col-sm-8">@Model.Status</dd>
    </dl>

    <form asp-action="Delete" method="post">
        <input type="hidden" asp-for="Room_ID" />
        <button type="submit" class="btn btn-danger btn-sm">Delete</button>
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm">Cancel</a>
    </form>
</div>