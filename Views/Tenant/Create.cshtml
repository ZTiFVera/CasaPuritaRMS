@model CasaPuritaRMS.Models.Tenant

@{
    ViewData["Title"] = "Add Tenant";
}

<div class="card-panel form-card">

    <div class="form-header">
        <h6>Add New Tenant</h6>
        <p class="form-subtitle">Fill in the tenant's profile and contact information</p>
    </div>

    <form asp-action="Create" method="post">
        <div asp-validation-summary="ModelOnly" class="form-error-summary"></div>

        <!-- PERSONAL INFORMATION -->
        <div class="form-section">
            <h6 class="form-section-title">Personal Information</h6>

            <div class="form-grid">
                <div class="form-group">
                    <label asp-for="First_Name" class="form-label"></label>
                    <input asp-for="First_Name" class="form-control-custom" />
                    <span asp-validation-for="First_Name" class="form-error"></span>
                </div>
                <div class="form-group">
                    <label asp-for="Last_Name" class="form-label"></label>
                    <input asp-for="Last_Name" class="form-control-custom" />
                    <span asp-validation-for="Last_Name" class="form-error"></span>
                </div>
            </div>

            <div class="form-grid">
                <div class="form-group">
                    <label asp-for="Email" class="form-label"></label>
                    <input asp-for="Email" class="form-control-custom" />
                    <span asp-validation-for="Email" class="form-error"></span>
                </div>
                <div class="form-group">
                    <label asp-for="Contact_Number" class="form-label"></label>
                    <input asp-for="Contact_Number" class="form-control-custom" />
                    <span asp-validation-for="Contact_Number" class="form-error"></span>
                </div>
            </div>

            <div class="form-group form-group-full">
                <label asp-for="Address" class="form-label"></label>
                <input asp-for="Address" class="form-control-custom" />
                <span asp-validation-for="Address" class="form-error"></span>
            </div>
        </div>

        <!-- EMERGENCY CONTACT -->
        <div class="form-section">
            <h6 class="form-section-title">Emergency Contact</h6>

            <div class="form-grid">
                <div class="form-group">
                    <label asp-for="Emergency_Contact_Name" class="form-label"></label>
                    <input asp-for="Emergency_Contact_Name" class="form-control-custom" />
                </div>
                <div class="form-group">
                    <label asp-for="Emergency_Contact_Number" class="form-label"></label>
                    <input asp-for="Emergency_Contact_Number" class="form-control-custom" />
                </div>
            </div>
        </div>

        <!-- STATUS -->
        <div class="form-section">
            <h6 class="form-section-title">Status</h6>

            <div class="form-group form-group-full">
                <label asp-for="Occupancy_Status" class="form-label"></label>
                <select asp-for="Occupancy_Status" class="form-control-custom">
                    <option value="Active">Active</option>
                    <option value="Inactive">Inactive</option>
                </select>
            </div>
        </div>

        <!-- ACTIONS -->
        <div class="form-actions">
            <a asp-action="Index" class="btn btn-outline-secondary btn-sm">Cancel</a>
            <button type="submit" class="btn btn-primary btn-sm">
                <i class="bi bi-check-lg"></i> Save Tenant
            </button>
        </div>
    </form>
</div>