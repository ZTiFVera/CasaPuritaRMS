@model CasaPuritaRMS.Models.Tenant

@{
    ViewData["Title"] = "Tenant Details";
    string initials = $"{Model.First_Name?.Substring(0, 1)}{Model.Last_Name?.Substring(0, 1)}".ToUpper();
    string statusClass = Model.Occupancy_Status == "Active" ? "badge-available" : "badge-occupied";
}

<div class="card-panel detail-card">

    <!-- PROFILE HEADER -->
    <div class="detail-header">
        <div class="detail-avatar">@initials</div>
        <div class="detail-header-info">
            <h5>@Model.First_Name @Model.Last_Name</h5>
            <span class="@statusClass">@Model.Occupancy_Status</span>
        </div>
    </div>

    <!-- CONTACT INFORMATION -->
    <div class="detail-section">
        <h6 class="detail-section-title">Contact Information</h6>
        <div class="detail-grid">
            <div class="detail-item">
                <span class="detail-label">Email</span>
                <span class="detail-value">@Model.Email</span>
            </div>
            <div class="detail-item">
                <span class="detail-label">Contact Number</span>
                <span class="detail-value">@Model.Contact_Number</span>
            </div>
            <div class="detail-item detail-item-full">
                <span class="detail-label">Address</span>
                <span class="detail-value">@Model.Address</span>
            </div>
        </div>
    </div>

    <!-- EMERGENCY CONTACT -->
    <div class="detail-section">
        <h6 class="detail-section-title">Emergency Contact</h6>
        <div class="detail-grid">
            <div class="detail-item">
                <span class="detail-label">Name</span>
                <span class="detail-value">@Model.Emergency_Contact_Name</span>
            </div>
            <div class="detail-item">
                <span class="detail-label">Contact Number</span>
                <span class="detail-value">@Model.Emergency_Contact_Number</span>
            </div>
        </div>
    </div>

    <!-- ACTIONS -->
    <div class="detail-actions">
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-arrow-left"></i> Back to List
        </a>
        <a asp-action="Edit" asp-route-id="@Model.Tenant_ID" class="btn btn-primary btn-sm">
            <i class="bi bi-pencil"></i> Edit Tenant
        </a>
    </div>

</div>