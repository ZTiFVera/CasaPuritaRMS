@model CasaPuritaRMS.Models.Tenant

@{
    ViewData["Title"] = "Delete Tenant";
    string initials = $"{Model.First_Name?.Substring(0, 1)}{Model.Last_Name?.Substring(0, 1)}".ToUpper();
}

<div class="card-panel delete-card">

    <div class="delete-icon-wrap">
        <i class="bi bi-exclamation-triangle-fill"></i>
    </div>

    <h6 class="delete-title">Delete this tenant?</h6>
    <p class="delete-subtitle">
        This action is permanent and cannot be undone. All records associated with this tenant will remain, but the tenant profile itself will be removed.
    </p>

    <div class="delete-preview">
        <div class="delete-avatar">@initials</div>
        <div class="delete-preview-info">
            <span class="delete-preview-name">@Model.First_Name @Model.Last_Name</span>
            <span class="delete-preview-meta">@Model.Email &middot; @Model.Contact_Number</span>
            <span class="delete-preview-meta">Status: @Model.Occupancy_Status</span>
        </div>
    </div>

    <form asp-action="Delete" method="post">
        <input type="hidden" asp-for="Tenant_ID" />
        <div class="form-actions">
            <a asp-action="Index" class="btn btn-outline-secondary btn-sm">Cancel</a>
            <button type="submit" class="btn btn-danger-custom btn-sm">
                <i class="bi bi-trash"></i> Delete Tenant
            </button>
        </div>
    </form>

</div>