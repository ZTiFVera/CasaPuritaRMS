@model CasaPuritaRMS.Models.Tenant

@{
    ViewData["Title"] = "Delete Tenant";
}

<div class="card-panel" style="max-width:600px;">
    <h6 class="mb-3 text-danger">Delete Tenant</h6>

    <div class="alert alert-danger py-2">
        Are you sure you want to delete this tenant? This action cannot be undone.
    </div>

    <dl class="row">
        <dt class="col-sm-4 text-muted small">First Name</dt>
        <dd class="col-sm-8">@Model.First_Name</dd>

        <dt class="col-sm-4 text-muted small">Last Name</dt>
        <dd class="col-sm-8">@Model.Last_Name</dd>

        <dt class="col-sm-4 text-muted small">Email</dt>
        <dd class="col-sm-8">@Model.Email</dd>

        <dt class="col-sm-4 text-muted small">Contact Number</dt>
        <dd class="col-sm-8">@Model.Contact_Number</dd>

        <dt class="col-sm-4 text-muted small">Occupancy Status</dt>
        <dd class="col-sm-8">@Model.Occupancy_Status</dd>
    </dl>

    <form asp-action="Delete" method="post">
        <input type="hidden" asp-for="Tenant_ID" />
        <button type="submit" class="btn btn-danger btn-sm">Delete</button>
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm">Cancel</a>
    </form>
</div>