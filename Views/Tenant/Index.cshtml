@model IEnumerable<CasaPuritaRMS.Models.Tenant>

@{
    ViewData["Title"] = "Tenants";
}

<div class="card-panel">

    <div class="card-panel-header">
        <h6>Tenant List</h6>
        <a asp-action="Create" class="btn btn-sm btn-primary">
            <i class="bi bi-plus-lg"></i> Add Tenant
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success py-2 mx-4 mt-3">@TempData["Success"]</div>
    }

    <table class="table align-middle">
        <thead>
            <tr>
                <th style="width:18%">Name</th>
                <th style="width:14%">Contact</th>
                <th style="width:22%">Address</th>
                <th style="width:20%">Email</th>
                <th style="width:10%">Status</th>
                <th style="width:16%" class="text-end">Actions</th>
            </tr>
        </thead>
        <tbody>
            @if (!Model.Any())
            {
                <tr>
                    <td colspan="6" class="text-center text-muted py-5">
                        <i class="bi bi-people fs-3 d-block mb-2"></i>
                        No tenants found. Click "Add Tenant" to create one.
                    </td>
                </tr>
            }
            @foreach (var tenant in Model)
            {
                <tr>
                    <td>@tenant.First_Name @tenant.Last_Name</td>
                    <td>@tenant.Contact_Number</td>
                    <td>@tenant.Address</td>
                    <td>@tenant.Email</td>
                    <td>
                        @if (tenant.Occupancy_Status == "Active")
                        {
                            <span class="badge-available">Active</span>
                        }
                        else
                        {
                            <span class="badge-occupied">@tenant.Occupancy_Status</span>
                        }
                    </td>
                    <td class="text-end">
                        <div class="btn-group btn-group-sm" role="group">
                            <a asp-action="Edit" asp-route-id="@tenant.Tenant_ID" class="btn btn-outline-secondary" title="Edit">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <a asp-action="Details" asp-route-id="@tenant.Tenant_ID" class="btn btn-outline-secondary" title="View">
                                <i class="bi bi-eye"></i>
                            </a>
                            <a asp-action="Delete" asp-route-id="@tenant.Tenant_ID" class="btn btn-outline-danger" title="Delete">
                                <i class="bi bi-trash"></i>
                            </a>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>