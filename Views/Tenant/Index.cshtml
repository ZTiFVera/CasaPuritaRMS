@model IEnumerable<CasaPuritaRMS.Models.Tenant>

@{
    ViewData["Title"] = "Tenants";

    var list = Model.ToList();
    int current = list.Count(t => t.Occupancy_Status == "Active");
    int inactive = list.Count(t => t.Occupancy_Status != "Active");
    var today = DateTime.Today;
    int expiringSoon = list.Count(t => t.Occupancy_Status == "Active"
        && (t.Contract_End_Date - today).TotalDays <= 30 && t.Contract_End_Date >= today);
}

<div class="tenant-summary-grid">
    <div class="summary-card">
        <div class="summary-icon"><i class="bi bi-people"></i></div>
        <span class="summary-label">Current Tenants</span>
        <span class="summary-value">@current</span>
    </div>
    <div class="summary-card">
        <div class="summary-icon"><i class="bi bi-hourglass-split"></i></div>
        <span class="summary-label">Contracts Expiring Soon</span>
        <span class="summary-value text-red">@expiringSoon</span>
    </div>
    <div class="summary-card">
        <div class="summary-icon"><i class="bi bi-person-dash"></i></div>
        <span class="summary-label">Inactive</span>
        <span class="summary-value">@inactive</span>
    </div>
</div>

<div class="card-panel">

    <div class="card-panel-header">
        <h6>Current Tenants (@current)</h6>
        <a asp-action="Create" class="btn btn-sm btn-primary">
            <i class="bi bi-plus-lg"></i> Add Tenant
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success py-2 mx-4 mt-3">@TempData["Success"]</div>
    }

    <table class="table align-middle">
        <thead>
            <tr>
                <th style="width:20%">Renter</th>
                <th style="width:22%">Address</th>
                <th style="width:10%">Unit</th>
                <th style="width:13%">Rent</th>
                <th style="width:15%">Move-In</th>
                <th style="width:15%">Lease End</th>
                <th style="width:5%" class="text-end">Status</th>
            </tr>
        </thead>
        <tbody>
            @if (!list.Any())
            {
                <tr>
                    <td colspan="7" class="text-center text-muted py-5">
                        <i class="bi bi-people fs-3 d-block mb-2"></i>
                        No tenants found. Click "Add Tenant" to create one.
                    </td>
                </tr>
            }
            @foreach (var t in list)
            {
                <tr class="clickable-row" data-href="@Url.Action("Details", new { id = t.Tenant_ID })">
                    <td>
                        <div class="renter-cell">
                            <div class="renter-avatar">@(t.First_Name.Substring(0, 1))@(t.Last_Name.Substring(0, 1))</div>
                            <span>@t.First_Name @t.Last_Name</span>
                        </div>
                    </td>
                    <td>@t.Address</td>
                    <td>@(t.Unit != null ? t.Unit.Unit_Number : "-")</td>
                    <td>@(t.Unit != null ? "₱" + t.Unit.Monthly_Price.ToString("N2") : "-")</td>
                    <td>@t.Move_In_Date.ToString("MM/dd/yyyy")</td>
                    <td>@t.Contract_End_Date.ToString("MM/dd/yyyy")</td>
                    <td class="text-end">
                        @if (t.Occupancy_Status == "Active")
                        {
                            <span class="badge-available">Active</span>
                        }
                        else
                        {
                            <span class="badge-occupied">@t.Occupancy_Status</span>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@section Scripts {
    <script>
        // Clicking a row opens the tenant profile.
        document.querySelectorAll('.clickable-row').forEach(function(row) {
            row.addEventListener('click', function() {
                window.location = this.dataset.href;
            });
        });
    </script>
}