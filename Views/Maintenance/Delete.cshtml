@model CasaPuritaRMS.Models.MaintenanceRequest

@{
    ViewData["Title"] = "Delete Maintenance Request";
}

<div class="card-panel delete-card">

    <div class="delete-icon-wrap">
        <i class="bi bi-exclamation-triangle-fill"></i>
    </div>

    <h6 class="delete-title">Delete this maintenance request?</h6>
    <p class="delete-subtitle">
        This action is permanent and cannot be undone. The request and its attachment reference will be removed.
    </p>

    <div class="delete-preview">
        <div class="delete-avatar delete-avatar-icon">
            <i class="bi bi-tools"></i>
        </div>
        <div class="delete-preview-info">
            <span class="delete-preview-name">@Model.Title</span>
            <span class="delete-preview-meta">@Model.Tenant?.First_Name @Model.Tenant?.Last_Name</span>
            <span class="delete-preview-meta">Submitted @Model.Date_Submitted.ToString("MMM dd, yyyy")</span>
        </div>
        <span class="badge-maintenance delete-preview-badge">@Model.Status</span>
    </div>

    <form asp-action="Delete" method="post">
        <input type="hidden" asp-for="Request_ID" />
        <div class="form-actions">
            <a asp-action="Index" class="btn btn-outline-secondary btn-sm">Cancel</a>
            <button type="submit" class="btn btn-danger-custom btn-sm">
                <i class="bi bi-trash"></i> Delete Request
            </button>
        </div>
    </form>

</div>