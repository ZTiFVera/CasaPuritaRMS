@model CasaPuritaRMS.Models.MaintenanceRequest

@{
    ViewData["Title"] = "Update Maintenance Request";
}

<div class="card-panel form-card">

    <div class="form-header">
        <h6>Update Maintenance Request</h6>
        <p class="form-subtitle">Update the request details and status</p>
    </div>

    <form asp-action="Edit" method="post" enctype="multipart/form-data">
        <input type="hidden" asp-for="Request_ID" />
        <input type="hidden" asp-for="Date_Submitted" />
        <input type="hidden" asp-for="Attachment_Path" />
        <div asp-validation-summary="ModelOnly" class="form-error-summary"></div>

        <div class="form-section">
            <h6 class="form-section-title">Request Details</h6>

            <div class="form-group form-group-full">
                <label asp-for="Tenant_ID" class="form-label">Tenant</label>
                <select asp-for="Tenant_ID" class="form-control-custom" asp-items="ViewBag.Tenant_ID">
                    <option value="">-- Select Tenant --</option>
                </select>
                <span asp-validation-for="Tenant_ID" class="form-error"></span>
            </div>

            <div class="form-group form-group-full">
                <label asp-for="Title" class="form-label"></label>
                <input asp-for="Title" class="form-control-custom" />
                <span asp-validation-for="Title" class="form-error"></span>
            </div>

            <div class="form-group form-group-full">
                <label asp-for="Description" class="form-label"></label>
                <textarea asp-for="Description" class="form-control-custom" rows="4"></textarea>
                <span asp-validation-for="Description" class="form-error"></span>
            </div>

            <div class="form-group form-group-full">
                <label asp-for="Status" class="form-label"></label>
                <select asp-for="Status" class="form-control-custom">
                    <option value="Open">Open</option>
                    <option value="In Progress">In Progress</option>
                    <option value="Resolved">Resolved</option>
                </select>
                <span asp-validation-for="Status" class="form-error"></span>
            </div>

            <div class="form-group form-group-full">
                <label class="form-label">Replace Attachment (optional)</label>
                <input type="file" name="attachment" class="form-control-custom" accept="image/*,.pdf" />
                @if (!string.IsNullOrEmpty(Model.Attachment_Path))
                {
                    <small class="text-muted">Current file kept unless a new one is chosen.</small>
                }
            </div>
        </div>

        <div class="form-actions">
            <a asp-action="Index" class="btn btn-outline-secondary btn-sm">Cancel</a>
            <button type="submit" class="btn btn-primary btn-sm">
                <i class="bi bi-check-lg"></i> Update Request
            </button>
        </div>
    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}