@model CasaPuritaRMS.Models.Unit

@{
    ViewData["Title"] = "Add Unit";
}

<div class="card-panel form-card form-card-sm">

    <div class="form-header">
        <h6>Add New Unit</h6>
        <p class="form-subtitle">Register a new rental unit and its details</p>
    </div>

    <form asp-action="Create" method="post">
        <div asp-validation-summary="ModelOnly" class="form-error-summary"></div>

        <div class="form-section">
            <h6 class="form-section-title">Unit Information</h6>

            <div class="form-grid">
                <div class="form-group">
                    <label asp-for="Unit_Number" class="form-label"></label>
                    <input asp-for="Unit_Number" class="form-control-custom" />
                    <span asp-validation-for="Unit_Number" class="form-error"></span>
                </div>
                <div class="form-group">
                    <label asp-for="Floor" class="form-label"></label>
                    <input asp-for="Floor" class="form-control-custom" />
                    <span asp-validation-for="Floor" class="form-error"></span>
                </div>
            </div>

            <div class="form-grid">
                <div class="form-group">
                    <label asp-for="Capacity" class="form-label"></label>
                    <input asp-for="Capacity" class="form-control-custom" />
                    <span asp-validation-for="Capacity" class="form-error"></span>
                </div>
                <div class="form-group">
                    <label asp-for="Status" class="form-label"></label>
                    <select asp-for="Status" class="form-control-custom">
                        <option value="Available">Available</option>
                        <option value="Occupied">Occupied</option>
                        <option value="Maintenance">Maintenance</option>
                    </select>
                </div>
            </div>

            <div class="form-group form-group-full">
                <div class="form-check-custom">
                    <input asp-for="Comfort_Room" class="form-check-input-custom" />
                    <label asp-for="Comfort_Room" class="form-check-label-custom">With Comfort Room (CR)</label>
                </div>
            </div>
        </div>

        <div class="form-actions">
            <a asp-action="Index" class="btn btn-outline-secondary btn-sm">Cancel</a>
            <button type="submit" class="btn btn-primary btn-sm">
                <i class="bi bi-check-lg"></i> Save Unit
            </button>
        </div>
    </form>
</div>