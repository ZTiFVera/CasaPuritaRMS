@model IEnumerable<CasaPuritaRMS.Models.Unit>

@{
    ViewData["Title"] = "Unit";
}

<div class="card-panel">

    <div class="card-panel-header">
        <h6>Unit List</h6>
        <a asp-action="Create" class="btn btn-sm btn-primary">
            <i class="bi bi-plus-lg"></i> Add Unit
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success py-2 mx-4 mt-3">@TempData["Success"]</div>
    }

    <table class="table align-middle">
        <thead>
            <tr>
                <th style="width:16%">Unit Number</th>
                <th style="width:10%">Floor</th>
                <th style="width:10%">Capacity</th>
                <th style="width:15%">Monthly Price</th>
                <th style="width:15%">Status</th>
                <th style="width:16%">Comfort Room</th>
                <th style="width:18%" class="text-end">Actions</th>
            </tr>
        </thead>
        <tbody>
            @if (!Model.Any())
            {
                <tr>
                    <td colspan="7" class="text-center text-muted py-5">
                        <i class="bi bi-door-open fs-3 d-block mb-2"></i>
                        No units found. Click "Add Unit" to create one.
                    </td>
                </tr>
            }
            @foreach (var unit in Model)
            {
                <tr>
                    <td>@unit.Unit_Number</td>
                    <td>@unit.Floor</td>
                    <td>@unit.Capacity</td>
                    <td>₱@unit.Monthly_Price.ToString("N2")</td>

                    <td>
                        @if (unit.Status == "Available")
                        {
                            <span class="badge-available">Available</span>
                        }
                        else if (unit.Status == "Occupied")
                        {
                            <span class="badge-occupied">Occupied</span>
                        }
                        else
                        {
                            <span class="badge-maintenance">@unit.Status</span>
                        }
                    </td>

                    <td>
                        @if (unit.Comfort_Room)
                        {
                            <span class="badge-yes">With CR</span>
                        }
                        else
                        {
                            <span class="badge-no">Without CR</span>
                        }
                    </td>

                    <td class="text-end">
                        <div class="btn-group btn-group-sm" role="group">
                            <a asp-action="Edit" asp-route-id="@unit.Unit_ID" class="btn btn-outline-secondary" title="Edit">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <a asp-action="Details" asp-route-id="@unit.Unit_ID" class="btn btn-outline-secondary" title="View">
                                <i class="bi bi-eye"></i>
                            </a>
                            <a asp-action="Delete" asp-route-id="@unit.Unit_ID" class="btn btn-outline-danger" title="Delete">
                                <i class="bi bi-trash"></i>
                            </a>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>