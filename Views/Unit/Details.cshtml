@model CasaPuritaRMS.Models.Unit

@{
    ViewData["Title"] = "Unit Details";
}

<div class="card-panel" style="max-width:600px;">
    <h6 class="mb-3">Unit Details</h6>

    <dl class="row">
        <dt class="col-sm-4 text-muted small">Unit Number</dt>
        <dd class="col-sm-8">@Model.Unit_Number</dd>

        <dt class="col-sm-4 text-muted small">Floor</dt>
        <dd class="col-sm-8">@Model.Floor</dd>

        <dt class="col-sm-4 text-muted small">Capacity</dt>
        <dd class="col-sm-8">@Model.Capacity</dd>

        <dt class="col-sm-4 text-muted small">Status</dt>
       
        <dd class="col-sm-8">
            @if (Model.Status == "Available")
            {
                <span class="badge-available">Available</span>
            }
            else if(Model.Status == "Occupied")
            {
                <span class="badge-occupied">Occupied</span>
            }
            else
            {
            <span class="badge-maintenance">Maintenance</span>
            }
        </dd>
        <dt class="col-sm-4 text-muted small">Comfort Room</dt>
        <dd class="col-sm-8">
            @if (Model.Comfort_Room)
            {
                <span class="badge-yes">With CR</span>
            }
            else
            {
                <span class="badge-no">Without CR</span>
            }
        </dd>

     
    </dl>

    <a asp-action="Edit" asp-route-id="@Model.Unit_ID" class="btn btn-primary btn-sm">Edit</a>
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">Back to List</a>
</div>