@model CasaPuritaRMS.Models.Unit

@{
    ViewData["Title"] = "Unit Details";

    string statusClass = Model.Status switch
    {
        "Available" => "badge-available",
        "Occupied" => "badge-occupied",
        _ => "badge-maintenance"
    };
}

<div class="card-panel detail-card">

    <div class="detail-header">
        <div class="detail-avatar detail-avatar-icon">
            <i class="bi bi-door-open"></i>
        </div>
        <div class="detail-header-info">
            <h5>Unit @Model.Unit_Number</h5>
            <span class="@statusClass">@Model.Status</span>
        </div>
    </div>

    <div class="detail-section">
        <h6 class="detail-section-title">Unit Information</h6>
        <div class="detail-grid">
            <div class="detail-item">
                <span class="detail-label">Floor</span>
                <span class="detail-value">@Model.Floor</span>
            </div>
            <div class="detail-item">
                <span class="detail-label">Capacity</span>
                <span class="detail-value">@Model.Capacity</span>
            </div>
            <div class="detail-item">
                <span class="detail-label">Monthly Price</span>
                <span class="detail-value">₱@Model.Monthly_Price.ToString("N2")</span>
            </div>
            <div class="detail-item">
                <span class="detail-label">Comfort Room</span>
                @if (Model.Comfort_Room)
                {
                    <span class="badge-yes">With CR</span>
                }
                else
                {
                    <span class="badge-no">Without CR</span>
                }
            </div>
        </div>
    </div>

    <div class="detail-actions">
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-arrow-left"></i> Back to List
        </a>
        <a asp-action="Edit" asp-route-id="@Model.Unit_ID" class="btn btn-primary btn-sm">
            <i class="bi bi-pencil"></i> Edit Unit
        </a>
    </div>

</div>