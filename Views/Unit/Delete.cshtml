@model CasaPuritaRMS.Models.Unit

@{
    ViewData["Title"] = "Delete Unit";

    string statusClass = Model.Status switch
    {
        "Available" => "badge-available",
        "Occupied" => "badge-occupied",
        _ => "badge-maintenance"
    };
}

<div class="card-panel delete-card">

    <div class="delete-icon-wrap">
        <i class="bi bi-exclamation-triangle-fill"></i>
    </div>

    <h6 class="delete-title">Delete this unit?</h6>
    <p class="delete-subtitle">
        This action is permanent and cannot be undone. Any tenant assignments or history linked to this unit may be affected.
    </p>

    <div class="delete-preview">
        <div class="delete-avatar delete-avatar-icon">
            <i class="bi bi-door-open"></i>
        </div>
        <div class="delete-preview-info">
            <span class="delete-preview-name">Unit @Model.Unit_Number</span>
            <span class="delete-preview-meta">Floor @Model.Floor &middot; Capacity @Model.Capacity</span>
        </div>
        <span class="@statusClass delete-preview-badge">@Model.Status</span>
    </div>

    <form asp-action="Delete" method="post">
        <input type="hidden" asp-for="Unit_ID" />
        <div class="form-actions">
            <a asp-action="Index" class="btn btn-outline-secondary btn-sm">Cancel</a>
            <button type="submit" class="btn btn-danger-custom btn-sm">
                <i class="bi bi-trash"></i> Delete Unit
            </button>
        </div>
    </form>

</div>